#!/usr/bin/env bash
set -euo pipefail

# Fast failure on formatting for staged C/C++ changes only.
if [ -x ./format-staged.sh ]; then
  ./format-staged.sh
else
  echo "Missing ./format-staged.sh"
  exit 1
fi

# ---- clang-tidy (warning-only by default; set TIDY_ENFORCE=1 to block) ----
if [ -x ./tidy-staged.sh ]; then
  TIDY_ENFORCE="${TIDY_ENFORCE:-0}"
  ENFORCE="$TIDY_ENFORCE" ./tidy-staged.sh
fi
