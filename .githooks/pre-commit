#!/usr/bin/env bash
set -euo pipefail

# Fast failure on formatting for staged C/C++ changes only.
if [ -x ./check-format-staged.sh ]; then
  ./check-format-staged.sh
else
  echo "Missing ./check-format-staged.sh"
  exit 1
fi

# ---- clang-tidy (warning-only) ----
if [ -x ./tidy-staged.sh ]; then
  ENFORCE=0 ./tidy-staged.sh || true
fi
